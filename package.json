{
  "name": "openclaw-secure-sandbox",
  "version": "1.0.0",
  "private": true,
  "description": "Security-first Docker sandbox for OpenClaw",
  "scripts": {
    "up": "docker compose up -d --build",
    "down": "docker compose down",
    "restart": "docker compose down && docker compose up -d --build",
    "logs": "docker compose logs -f",
    "shell": "docker exec -it openclaw-test sh",
    "proxy:shell": "docker exec -it squid-proxy bash",
    "security:test": "docker exec -it openclaw-test sh /security-test.sh",
    "iptables": "docker exec -it openclaw-test iptables -L -n -v",
    "route": "docker exec -it openclaw-test ip route",
    "verify": "npm run route && npm run iptables && npm run security:test",
    "clean": "docker compose down -v --remove-orphans"
  }
}